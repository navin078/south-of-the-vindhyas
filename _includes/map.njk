<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} - South of the Vindhyas</title>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
  <link rel="stylesheet" href="{{ '/assets/site.css' | url }}">
</head>
<body class="map-page">
  <header class="map-header">
    <nav class="map-nav" aria-label="Primary">
      <a href="{{ '/' | url }}">Map</a>
      <a href="{{ '/blog/' | url }}">Blog</a>
    </nav>
  </header>
  {{ content | safe }}
  <script>
    window.siteConfig = {
      railwayLinesUrl: "{{ '/data/south-india-railways.geojson' | url }}",
      railwayStationsUrl: "{{ '/data/south-india-railwaystations.geojson' | url }}",
      postsIndexUrl: "{{ '/posts-index.json' | url }}"
    };
  </script>
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script src="{{ '/assets/map.js' | url }}"></script>
</body>
</html>
